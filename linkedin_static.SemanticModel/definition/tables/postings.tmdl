table postings
	lineageTag: 5d628111-8bfd-4ea1-a712-74fc9a3bee32

	measure remote_job_percentage =
			IF(
			    CALCULATE(COUNTA('postings'[remote_allowed]), 'postings'[remote_allowed] = 1) = 0,
			    0,
			    DIVIDE(CALCULATE(COUNTA('postings'[remote_allowed]), 'postings'[remote_allowed] = 1), COUNTA('postings'[remote_allowed])))
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 02cfb950-8a43-4350-bb0b-6d7646a72da7

	measure 'Application Rate' = ```
			
			    DIVIDE(SUM(postings[applies]), SUM('postings'[views]))
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: e71903d1-b7f2-4877-ada3-807b14a505b5

	measure 'all applies' = SUM(postings[applies])
		formatString: 0
		lineageTag: fb3f5787-280e-4bb0-af31-3daeede6d83d

	measure 'Avg Time to Close' =
			
			AVERAGEX(
			    postings,
			    COALESCE(postings[closed_date_time], postings[expiry_date_time]) - postings[listed_date_time]
			)
		lineageTag: 561f6262-0bdb-4490-abc4-57949d944a07

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Benefits per Job' = ```
			
			DIVIDE(
			    COUNTROWS(benefits), 
			    COUNTROWS(postings)
			)
			```
		lineageTag: 82ae17eb-6da8-4d1e-aa92-05ec2b3236f8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

